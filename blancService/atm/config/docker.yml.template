# docker.yml.template
#
# Rendered at container start by blancService/entrypoint.sh using
# `envsubst`. Only the ${VARS} listed in entrypoint.sh are substituted —
# everything else (YAML `$` for anchors, dict values, etc.) is left alone.
#
# The rendered file is written to /app/atm/config/docker.yml and read via
# ATM_CONFIG_PATH.

fastApiConfig:
  appHost: 0.0.0.0
  appPort: 8000
  num_workers: 1

openaiconfig:
  openai_url: "https://api.openai.com/v1"
  model_name: "gpt-4o"
  provider: "openai"
  # The client picks the key up from OPENAI_API_KEY at request time;
  # leave this blank.
  api_key: ""
  models:
    vision:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00
    summarization:
      model_name: "gpt-4o-mini"
      prompt_cost_per_million: 0.15
      completion_cost_per_million: 0.60
    component_analysis:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00
    clarification:
      model_name: "gpt-4o-mini"
      prompt_cost_per_million: 0.15
      completion_cost_per_million: 0.60
    threat_modeling:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00

pricing:
  prompt_cost_per_million: 2.50
  completion_cost_per_million: 10.00

rag_config:
  backend: "local"
  namespace: "appsec"
  collection_id: "blanc_default"
  local:
    persist_dir: "/app/data/chroma"
    collection_prefix: ""
  embedder:
    provider: "sentence_transformers"
    model_name: "all-MiniLM-L6-v2"
    api_key_env: "OPENAI_API_KEY"
  api_url: ""
  auth_token_env: "ATM_RAG_API_KEY"

storage:
  backend: "local"
  local_upload_dir: "/app/uploads"

google_auth:
  client_id: "${GOOGLE_CLIENT_ID}"
  client_secret: "${GOOGLE_CLIENT_SECRET}"
  redirect_uri: "${GOOGLE_REDIRECT_URI}"
  allowed_domain: "${ALLOWED_DOMAIN}"

frontend:
  base_url: "${FRONTEND_BASE_URL}"

admin_users:
  - "${ADMIN_EMAIL}"

logging:
  version: 1
  disable_existing_loggers: False
  formatters:
    simple:
      (): colorlog.ColoredFormatter
      format: "%(log_color)s%(levelname)-8s%(reset)s %(cyan)s%(filename)s:%(lineno)d%(reset)s - %(message)s"
      log_colors:
        DEBUG: white
        INFO: green
        WARNING: yellow
        ERROR: red
        CRITICAL: bold_red
  handlers:
    console:
      class: logging.StreamHandler
      level: INFO
      formatter: simple
      stream: ext://sys.stdout
  loggers:
    aio_pika:      { level: ERROR,   handlers: [console], propagate: no }
    aiormq:        { level: ERROR,   handlers: [console], propagate: no }
    httpx:         { level: WARNING, handlers: [console], propagate: no }
    httpcore:      { level: WARNING, handlers: [console], propagate: no }
    openai:        { level: WARNING, handlers: [console], propagate: no }
  root:
    level: INFO
    handlers: [console]

paths:
  base_dir: /app

jwt_config:
  secret_key: "${JWT_SECRET_KEY}"
  algorithm: HS256
  access_token_expire_minutes: 60

dbConfig:
  mariadbConnectionString: "mariadb+mariadbconnector://${MARIADB_USER}:${MARIADB_PASSWORD}@mariadb:3306/${MARIADB_DATABASE}"
  poolSize: 20
  poolRecycle: 300
  maxOverflow: 20

rmqConfig:
  hosts:
    - rabbitmq
  port: 5672
  username: "${RABBITMQ_USER}"
  password: "${RABBITMQ_PASSWORD}"
  prefetchCount: 1
  routingKey: scan
  sslEnabled: False
  queues:
    - name: ATM
      concurrency: 10
