# Blanc — configuration for `docker compose up`.
#
#   cp docker.yml.example docker.yml
#   # edit docker.yml, fill in real secrets, then:
#   docker compose up --build
#
# The compose file mounts this into the api container at
#   /app/atm/config/docker.yml
# and the entrypoint points ATM_CONFIG_PATH at it.
#
# NOTE: `mariadbConnectionString` and `rmqConfig.hosts` reference the
# service names from docker-compose.yml (mariadb, rabbitmq) — do not
# change those unless you also rename the compose services.

fastApiConfig:
  appHost: 0.0.0.0
  appPort: 8000
  num_workers: 1

openaiconfig:
  openai_url: "https://api.openai.com/v1"
  model_name: "gpt-4o"
  provider: "openai"
  # Get a key at https://platform.openai.com/api-keys.
  api_key: "sk-REPLACE_ME"
  models:
    vision:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00
    summarization:
      model_name: "gpt-4o-mini"
      prompt_cost_per_million: 0.15
      completion_cost_per_million: 0.60
    component_analysis:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00
    clarification:
      model_name: "gpt-4o-mini"
      prompt_cost_per_million: 0.15
      completion_cost_per_million: 0.60
    threat_modeling:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00

pricing:
  prompt_cost_per_million: 2.50
  completion_cost_per_million: 10.00

rag_config:
  backend: "local"
  namespace: "appsec"
  collection_id: "blanc_default"
  local:
    persist_dir: "/app/data/chroma"
    collection_prefix: ""
  embedder:
    # `sentence_transformers` runs locally (no API key). Switch to
    # `openai` to use the OpenAI embeddings API instead — the key
    # under `openaiconfig.api_key` above is reused.
    provider: "sentence_transformers"
    model_name: "all-MiniLM-L6-v2"
    api_key: ""
    api_key_env: "OPENAI_API_KEY"
  api_url: ""
  auth_token_env: "ATM_RAG_API_KEY"

storage:
  backend: "local"
  local_upload_dir: "/app/uploads"

# Leave google_auth.client_id / client_secret blank to disable
# Google sign-in. The block itself must be present.
google_auth:
  client_id: ""
  client_secret: ""
  redirect_uri: "http://localhost:8000/auth/google/callback"
  allowed_domain: ""

frontend:
  base_url: "http://localhost:3000"

# First admin — used to seed the admin_users list on boot.
admin_users:
  - "admin@example.com"

logging:
  version: 1
  disable_existing_loggers: False
  formatters:
    simple:
      (): colorlog.ColoredFormatter
      format: "%(log_color)s%(levelname)-8s%(reset)s %(cyan)s%(filename)s:%(lineno)d%(reset)s - %(message)s"
      log_colors:
        DEBUG: white
        INFO: green
        WARNING: yellow
        ERROR: red
        CRITICAL: bold_red
  handlers:
    console:
      class: logging.StreamHandler
      level: INFO
      formatter: simple
      stream: ext://sys.stdout
  loggers:
    aio_pika:      { level: ERROR,   handlers: [console], propagate: no }
    aiormq:        { level: ERROR,   handlers: [console], propagate: no }
    httpx:         { level: WARNING, handlers: [console], propagate: no }
    httpcore:      { level: WARNING, handlers: [console], propagate: no }
    openai:        { level: WARNING, handlers: [console], propagate: no }
  root:
    level: INFO
    handlers: [console]

paths:
  base_dir: /app

jwt_config:
  # Generate with:
  #   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
  # Must be >= 32 chars. Anything starting with "CHANGE_ME" is rejected.
  secret_key: "CHANGE_ME_to_a_48_char_url_safe_random_string"
  algorithm: HS256
  access_token_expire_minutes: 60

dbConfig:
  # These credentials must match the mariadb service in docker-compose.yml.
  # Defaults: user=atm / password=atm / database=atm.
  mariadbConnectionString: "mariadb+mariadbconnector://atm:atm@mariadb:3306/atm"
  poolSize: 20
  poolRecycle: 300
  maxOverflow: 20

rmqConfig:
  # Matches the rabbitmq service in docker-compose.yml (user=guest / pass=guest).
  hosts:
    - rabbitmq
  port: 5672
  username: "guest"
  password: "guest"
  prefetchCount: 1
  routingKey: scan
  sslEnabled: False
  queues:
    - name: ATM
      concurrency: 10
