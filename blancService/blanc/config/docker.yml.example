# Blanc — configuration for `docker compose up`.
#
#   cp docker.yml.example docker.yml
#   # edit docker.yml, fill in real secrets, then:
#   docker compose up --build
#
# The compose file mounts this into the api container at
#   /app/blanc/config/docker.yml
# and the entrypoint points BLANC_CONFIG_PATH at it.
#
# NOTE: `mariadbConnectionString` and `rmqConfig.hosts` reference the
# service names from docker-compose.yml (mariadb, rabbitmq) — do not
# change those unless you also rename the compose services.

fastApiConfig:
  appHost: 0.0.0.0
  appPort: 8000
  num_workers: 1

openaiconfig:
  openai_url: "https://api.openai.com/v1"
  model_name: "gpt-4o"
  provider: "openai"
  # Get a key at https://platform.openai.com/api-keys.
  api_key: "sk-REPLACE_ME"
  models:
    vision:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00
    summarization:
      model_name: "gpt-4o-mini"
      prompt_cost_per_million: 0.15
      completion_cost_per_million: 0.60
    component_analysis:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00
    clarification:
      model_name: "gpt-4o-mini"
      prompt_cost_per_million: 0.15
      completion_cost_per_million: 0.60
    threat_modeling:
      model_name: "gpt-4o"
      prompt_cost_per_million: 2.50
      completion_cost_per_million: 10.00

pricing:
  prompt_cost_per_million: 2.50
  completion_cost_per_million: 10.00

rag_config:
  backend: "local"
  namespace: "appsec"
  collection_id: "blanc_default"
  local:
    persist_dir: "/app/data/chroma"
    collection_prefix: ""
  embedder:
    # `sentence_transformers` runs locally (no API key). Switch to
    # `openai` to use the OpenAI embeddings API instead — the key
    # under `openaiconfig.api_key` above is reused.
    provider: "sentence_transformers"
    model_name: "all-MiniLM-L6-v2"
    api_key: ""
    api_key_env: "OPENAI_API_KEY"
  api_url: ""
  auth_token_env: "BLANC_RAG_API_KEY"

storage:
  backend: "local"
  local_upload_dir: "/app/uploads"

# Leave google_auth.client_id / client_secret blank to disable
# Google sign-in. The block itself must be present.
google_auth:
  client_id: ""
  client_secret: ""
  redirect_uri: "http://localhost:8000/auth/google/callback"
  allowed_domain: ""

frontend:
  base_url: "http://localhost:3000"

# First admin — used to seed the admin_users list on boot.
admin_users:
  - "admin@example.com"

logging:
  version: 1
  disable_existing_loggers: False
  formatters:
    simple:
      (): colorlog.ColoredFormatter
      format: "%(log_color)s%(levelname)-8s%(reset)s %(cyan)s%(filename)s:%(lineno)d%(reset)s %(bold_black)s[req:%(request_id)s aid:%(assessment_id)s img:%(image_id)s]%(reset)s - %(message)s"
      log_colors:
        DEBUG: white
        INFO: green
        WARNING: yellow
        ERROR: red
        CRITICAL: bold_red
  handlers:
    console:
      class: logging.StreamHandler
      level: INFO
      formatter: simple
      stream: ext://sys.stdout
  loggers:
    aio_pika:      { level: ERROR,   handlers: [console], propagate: no }
    aiormq:        { level: ERROR,   handlers: [console], propagate: no }
    httpx:         { level: WARNING, handlers: [console], propagate: no }
    httpcore:      { level: WARNING, handlers: [console], propagate: no }
    openai:        { level: WARNING, handlers: [console], propagate: no }
  root:
    level: INFO
    handlers: [console]

paths:
  base_dir: /app

jwt_config:
  # Generate with:
  #   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
  # Must be >= 32 chars. Anything starting with "CHANGE_ME" is rejected.
  secret_key: "CHANGE_ME_to_a_48_char_url_safe_random_string"
  algorithm: HS256
  access_token_expire_minutes: 60

dbConfig:
  # These credentials must match the mariadb service in docker-compose.yml.
  # Defaults: user=blanc / password=blanc / database=blanc.
  mariadbConnectionString: "mariadb+mariadbconnector://blanc:blanc@mariadb:3306/blanc"
  poolSize: 20
  poolRecycle: 300
  maxOverflow: 20

rmqConfig:
  # Matches the rabbitmq service in docker-compose.yml (user=guest / pass=guest).
  hosts:
    - rabbitmq
  port: 5672
  username: "guest"
  password: "guest"
  prefetchCount: 1
  routingKey: scan
  sslEnabled: False
  queues:
    - name: BLANC
      concurrency: 2


# ═════════════════════════════════════════════════════════════════════
# External integrations (OPTIONAL) — pluggable connectors that hydrate
# the surface_map from org-owned systems BEFORE threat modelling runs.
# The same block also drives clarification auto-answer when
# ``question.answer`` is set under ``field_sources``.
#
# The framework treats a missing or empty ``integrations`` block as a
# no-op — nothing external is called. Uncomment and adapt to wire your
# own integration.
#
# See ``blanc/modules/Example.py`` for a working reference connector.
# ═════════════════════════════════════════════════════════════════════

# integrations:
#
#   # Named credentials referenced by each connector's ``auth`` field.
#   #   ${env:VAR}    — read from os.environ at request time. In Docker
#   #                   pass secrets via docker-compose ``environment:``
#   #                   or an ``env_file:``.
#   #   ${token:X}    — resolved via register_token_source("X", fn)
#   #                   during app startup.
#   auth:
#     example_bearer:
#       header: "Authorization"
#       value:  "Bearer ${env:EXAMPLE_API_TOKEN}"
#
#   # Connector instances. Key = the class' ``name`` attribute.
#   # Only transport concerns live here — vendor-specific request-body
#   # knobs (prompts, model names, retriever names) belong in the
#   # connector class.
#   connectors:
#     Example:
#       module: blanc.modules.Example
#       auth:   example_bearer
#       url:    "https://your-agent-endpoint.example.com/ask"
#
#       # Optional per-deployment override of the vendor model alias.
#       # model: "your-model-alias"
#
#       # TLS verification. Accepts:
#       #   true               (default; verify against certifi bundle)
#       #   false              (curl -k equivalent)
#       #   "/path/to/ca.pem"  (verify against a specific PEM bundle,
#       #                       e.g. your org's private CA. Mount the
#       #                       PEM into the api container via a bind).
#       verify_ssl: true
#
#       timeout_s: 60
#       cache_ttl_s: 3600
#       max_concurrent_requests: 4
#       max_retries: 3
#       keepalive_expiry_s: 5
#       circuit_breaker_failures: 5
#       circuit_breaker_cooldown_s: 60
#
#       # SSRF guard — hard allow-list of hosts this connector may hit.
#       allowed_hosts:
#         - "your-agent-endpoint.example.com"
#
#   # Which connector(s) fill which target, in fallback order. First
#   # non-null result wins. Empty / omitted list = target left alone.
#   #
#   # Reserved key prefixes:
#   #   component.<field> — hydrated per component during Phase A
#   #   boundary.<field>  — hydrated per trust boundary during Phase A
#   #   question.answer   — external auto-answer for clarification
#   #                       questions; falls back to built-in RAG+LLM
#   field_sources:
#     "component.desc":        [Example]
#     # "component.exposure":    [Example]
#     # "component.environment": [Example]
