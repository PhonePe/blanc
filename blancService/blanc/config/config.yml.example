fastApiConfig:
  appHost: 0.0.0.0
  appPort: 8000
  num_workers: 1

openaiconfig:
  openai_url: "https://api.openai.com/v1"
  model_name: "gpt-4o"
  provider: "openai"
  # Prefer OPENAI_API_KEY in the environment. This optional value is only for
  # local/dev overrides where environment-based secrets are unavailable.
  api_key: ""
  models:
    vision:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    summarization:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    component_analysis:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    clarification:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    threat_modeling:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0


pricing:
  prompt_cost_per_million: 30.0
  completion_cost_per_million: 60.0

# RAG backend:
#   "local" — in-process Chroma; zero infra, uses `local` + `embedder` blocks.
#   "http"  — remote vector-DB API; uses `api_url` + `auth_token_env`.
rag_config:
  backend: "local"
  namespace: "appsec"
  collection_id: "blanc_default"

  # Used only when backend == "local":
  local:
    persist_dir: "./data/chroma"
    collection_prefix: ""
  embedder:
    # provider: "sentence_transformers" | "openai"
    provider: "sentence_transformers"
    # For sentence_transformers: any model on HuggingFace (e.g. "all-MiniLM-L6-v2").
    # For openai:               "text-embedding-3-small" / "text-embedding-3-large".
    model_name: "all-MiniLM-L6-v2"
    api_key_env: "OPENAI_API_KEY"    # only read when provider == "openai"

  # Used only when backend == "http":
  api_url: ""
  auth_token_env: "BLANC_RAG_API_KEY"

# Storage backend: "local" or "s3"
storage:
  backend: "local"
  local_upload_dir: "uploads"

google_auth:
  client_id: "CHANGE_ME.apps.googleusercontent.com"
  client_secret: ""
  redirect_uri: "http://localhost:8000/auth/google/callback"
  allowed_domain: "example.com"

frontend:
  base_url: "http://localhost:3000"

admin_users:
    - admin@example.com

logging:
  version: 1
  disable_existing_loggers: False
  formatters:
        simple:
            (): colorlog.ColoredFormatter
            format: "%(log_color)s%(levelname)-8s%(reset)s %(cyan)s%(filename)s:%(lineno)d%(reset)s %(bold_black)s[req:%(request_id)s aid:%(assessment_id)s img:%(image_id)s]%(reset)s - %(message)s"
            log_colors:
                DEBUG: white
                INFO: green
                WARNING: yellow
                ERROR: red
                CRITICAL: bold_red
  handlers:
    console:
      class: logging.StreamHandler
      level: DEBUG
      formatter: simple
      stream: ext://sys.stdout

  loggers:
    requests.packages.urllib3:
      level: INFO
      handlers: [console]
      propagate: no
    aio_pika:
      level: ERROR
      handlers: [ console ]
      propagate: no
    aiormq:
      level: ERROR
      handlers: [ console ]
      propagate: no
    httpx:
      level: WARNING
      handlers: [console]
      propagate: no
    httpcore:
      level: WARNING
      handlers: [console]
      propagate: no
    openai:
      level: WARNING
      handlers: [console]
      propagate: no

  root:
    level: DEBUG
    handlers: [console]

paths:
  base_dir: ./atm_backend

jwt_config:
  secret_key: "${JWT_SECRET_KEY:-local-dev-jwt-secret-rotate-before-sharing-2026-07-03}"
  algorithm: HS256
  access_token_expire_minutes: 300

dbConfig:
  mariadbConnectionString: mariadb+mariadbconnector://root:root@localhost:3306/blanc
  poolSize: 100
  poolRecycle: 300
  maxOverflow: 50

rmqConfig:
  hosts:
    - 127.0.0.1
  port: 5672
  username: guest
  password: guest
  prefetchCount: 1
  routingKey: scan
  sslEnabled: True
  queues:
      - name: BLANC
        concurrency: 2
