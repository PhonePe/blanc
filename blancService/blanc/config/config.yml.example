fastApiConfig:
  appHost: 0.0.0.0
  appPort: 8000
  num_workers: 1

openaiconfig:
  openai_url: "https://api.openai.com/v1"
  provider: "openai"
  # Prefer OPENAI_API_KEY in the environment. This optional value is only for
  # local/dev overrides where environment-based secrets are unavailable.
  api_key: ""

  # Fallback model + pricing. Used whenever a call doesn't match a
  # per-purpose entry under `models` below.
  default:
    model_name: "gpt-4o"
    pricing:
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0

  # Optional per-purpose overrides. Any purpose not listed here inherits
  # `default.model_name` + `default.pricing`.
  models:
    vision:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    summarization:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    component_analysis:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    clarification:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0
    threat_modeling:
      model_name: "gpt-4o"
      prompt_cost_per_million: 30.0
      completion_cost_per_million: 60.0


# RAG backend:
#   "local" — in-process Chroma; zero infra, uses `local` + `embedder` blocks.
#   "http"  — remote vector-DB API; uses `api_url` + `auth_token_env`.
rag_config:
  backend: "local"
  namespace: "appsec"
  collection_id: "blanc_default"

  # Used only when backend == "local":
  local:
    persist_dir: "./data/chroma"
    collection_prefix: ""
  embedder:
    # provider: "sentence_transformers" | "openai"
    provider: "sentence_transformers"
    # For sentence_transformers: any model on HuggingFace (e.g. "all-MiniLM-L6-v2").
    # For openai:               "text-embedding-3-small" / "text-embedding-3-large".
    model_name: "all-MiniLM-L6-v2"
    api_key_env: "OPENAI_API_KEY"    # only read when provider == "openai"

  # Used only when backend == "http":
  api_url: ""
  auth_token_env: "BLANC_RAG_API_KEY"

# Storage backend: "local" or "s3"
storage:
  backend: "local"
  local_upload_dir: "uploads"

google_auth:
  client_id: "CHANGE_ME.apps.googleusercontent.com"
  client_secret: ""
  redirect_uri: "http://localhost:8000/auth/google/callback"
  allowed_domain: "example.com"

frontend:
  base_url: "http://localhost:3000"

admin_users:
    - admin@example.com

logging:
  version: 1
  disable_existing_loggers: False
  formatters:
        simple:
            (): colorlog.ColoredFormatter
            format: "%(log_color)s%(levelname)-8s%(reset)s %(cyan)s%(filename)s:%(lineno)d%(reset)s %(bold_black)s[req:%(request_id)s aid:%(assessment_id)s img:%(image_id)s]%(reset)s - %(message)s"
            log_colors:
                DEBUG: white
                INFO: green
                WARNING: yellow
                ERROR: red
                CRITICAL: bold_red
  handlers:
    console:
      class: logging.StreamHandler
      level: DEBUG
      formatter: simple
      stream: ext://sys.stdout

  loggers:
    requests.packages.urllib3:
      level: INFO
      handlers: [console]
      propagate: no
    aio_pika:
      level: ERROR
      handlers: [ console ]
      propagate: no
    aiormq:
      level: ERROR
      handlers: [ console ]
      propagate: no
    httpx:
      level: WARNING
      handlers: [console]
      propagate: no
    httpcore:
      level: WARNING
      handlers: [console]
      propagate: no
    openai:
      level: WARNING
      handlers: [console]
      propagate: no

  root:
    level: DEBUG
    handlers: [console]

paths:
  base_dir: ./atm_backend

jwt_config:
  secret_key: "${JWT_SECRET_KEY:-local-dev-jwt-secret-rotate-before-sharing-2026-07-03}"
  algorithm: HS256
  access_token_expire_minutes: 300

dbConfig:
  mariadbConnectionString: mariadb+mariadbconnector://root:root@localhost:3306/blanc
  poolSize: 100
  poolRecycle: 300
  maxOverflow: 50

rmqConfig:
  hosts:
    - 127.0.0.1
  port: 5672
  username: guest
  password: guest
  prefetchCount: 1
  routingKey: scan
  sslEnabled: True
  queues:
      - name: BLANC
        concurrency: 2


# ═════════════════════════════════════════════════════════════════════
# External integrations (OPTIONAL) — pluggable connectors that hydrate
# the surface_map from org-owned systems BEFORE threat modelling runs.
# The same block also drives clarification auto-answer when
# ``question.answer`` is set under ``field_sources``.
#
# The framework treats a missing or empty ``integrations`` block as a
# no-op — nothing external is called. Uncomment and adapt to wire your
# own integration.
#
# See ``blanc/modules/Example.py`` for a working reference connector.
# ═════════════════════════════════════════════════════════════════════

# integrations:
#
#   # Read top-down:
#   #   field_sources — what needs filling, and by whom (in order)
#   #   connectors    — the upstreams referenced above (transport only)
#   #   auth          — the credentials each connector references
#
#   # 1. Routing. Which connector(s) fill which target, in fallback order.
#   # First non-null result wins. Empty / omitted list = target left alone.
#   #
#   # Reserved key prefixes:
#   #   component.<field> — hydrated per component during Phase A
#   #   boundary.<field>  — hydrated per trust boundary during Phase A
#   #   question.answer   — external auto-answer for clarification
#   #                       questions; falls back to built-in RAG+LLM
#   field_sources:
#     "component.desc":        [Example]
#     # "component.exposure":    [Example]
#     # "component.environment": [Example]
#     # "question.answer":       [Example]
#
#   # 2. Connector instances referenced above. Key = the class'
#   # ``name`` attribute. Only transport concerns live here — vendor-
#   # specific request-body knobs (prompts, model names, retriever
#   # names) belong in the connector class.
#   connectors:
#     Example:
#       module: blanc.modules.Example
#       auth:   example_bearer                     # ← references auth block below
#       url:    "https://your-agent-endpoint.example.com/ask"
#
#       # Optional per-deployment override of the vendor model alias
#       # (see Example.py — read via ``self.cfg.get("model", _DEFAULT_MODEL)``):
#       # model: "your-model-alias"
#
#       # TLS verification. Accepts:
#       #   true               (default; verify against certifi bundle)
#       #   false              (curl -k equivalent; use only when you
#       #                       control the upstream and can't install
#       #                       the CA locally)
#       #   "/path/to/ca.pem"  (verify against a specific PEM bundle,
#       #                       e.g. your org's private CA)
#       verify_ssl: true
#
#       # Transport tuning.
#       timeout_s: 60
#       cache_ttl_s: 3600
#       max_concurrent_requests: 4
#       max_retries: 3
#       keepalive_expiry_s: 5
#       circuit_breaker_failures: 5
#       circuit_breaker_cooldown_s: 60
#
#       # SSRF guard — hard allow-list of hosts this connector may hit.
#       allowed_hosts:
#         - "your-agent-endpoint.example.com"
#
#   # 3. Named credentials referenced by each connector's ``auth`` field.
#   #   ${env:VAR}    — read from os.environ at request time
#   #   ${token:X}    — resolved via register_token_source("X", fn)
#   #                   during app startup
#   auth:
#     example_bearer:
#       header: "Authorization"
#       value:  "Bearer ${env:EXAMPLE_API_TOKEN}"
